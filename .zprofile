export KEYTIMEOUT=0
export EDITOR=nvim
export VISUAL=nvim
export PATH=$HOMEBREW_PREFIX/bin:$HOMEBREW_PREFIX/sbin:$OPENSSL_DIR/bin:$HOMEBREW_PREFIX/opt/node/bin:$HOMEBREW_PREFIX/opt/ruby/bin:$HOMEBREW_PREFIX/lib/ruby/gems/3.4.0/bin:$ANDROID_HOME/cmdline-tools/latest/bin:$ANDROID_HOME/platform-tools:$GOPATH/bin:$HOME/.cargo/bin:$HOME/.dotnet/tools:$HOME/.local/bin:$HOME/bin:$PATH
export MANPATH="$HOMEBREW_PREFIX/share/man${MANPATH+:$MANPATH}:";
export INFOPATH="$HOMEBREW_PREFIX/share/info:${INFOPATH:-}";
