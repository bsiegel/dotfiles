shell-integration = zsh
font-family = CommitMono
theme = MyiTerm
mouse-hide-while-typing = true
cursor-click-to-move = true
font-size = 15
cursor-style = block
shell-integration-features = no-cursor
cursor-style-blink = false
background-opacity = 0.95
background-blur = true
background = 161616
quit-after-last-window-closed=true
adjust-cell-height=10%
window-height=40
window-width=150
bold-color=bright

keybind = cmd+opt+ctrl+-=new_split:down
keybind = cmd+opt+ctrl+\=new_split:right
keybind = cmd+opt+ctrl+left=goto_split:left
keybind = cmd+opt+ctrl+right=goto_split:right
keybind = cmd+opt+ctrl+down=goto_split:down
keybind = cmd+opt+ctrl+up=goto_split:up
keybind = cmd+opt+ctrl+space=equalize_splits
keybind = cmd+opt+ctrl+equal=toggle_split_zoom
keybind = cmd+opt+ctrl+shift+left=resize_split:left,10
keybind = cmd+opt+ctrl+shift+right=resize_split:right,10
keybind = cmd+opt+ctrl+shift+down=resize_split:down,10
keybind = cmd+opt+ctrl+shift+up=resize_split:up,10