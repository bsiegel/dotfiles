#!/usr/bin/env bash
set -euo pipefail

# Run git pull --prune, teeing output so the user sees it in real time
output=$(git pull --rebase --prune 2>&1 | tee /dev/fd/2)

# Find branches reported as deleted by the prune
deleted_remotes=()
while IFS= read -r line; do
  # Lines look like: " - [deleted]         (none)     -> origin/branch-name"
  if [[ $line =~ \[deleted\].*-\>\ *([^[:space:]]+) ]]; then
    ref="${BASH_REMATCH[1]}"
    # Strip the remote prefix (e.g. "origin/") to get the local branch name
    local_branch="${ref#*/}"
    deleted_remotes+=("$local_branch")
  fi
done <<<"$output"

# Filter to only branches that exist locally
candidates=()
for branch in "${deleted_remotes[@]+"${deleted_remotes[@]}"}"; do
  if git show-ref --verify --quiet "refs/heads/$branch"; then
    candidates+=("$branch")
  fi
done

[[ ${#candidates[@]} -eq 0 ]] && exit 0

# Sort alphabetically
IFS=$'\n' candidates=($(sort <<<"${candidates[*]}"))
unset IFS

echo ""
echo "Delete local branches?"
echo ""
for i in "${!candidates[@]}"; do
  printf "  %d) %s\n" $((i + 1)) "${candidates[$i]}"
done

while true; do
  echo ""
  read -rp "[(a)ll] / (n)one / range: " selection
  selection="${selection:-all}"

  # Determine which indices to delete
  indices=()
  valid=true
  case "$(printf '%s' "$selection" | tr '[:upper:]' '[:lower:]')" in
  all | a)
    for i in "${!candidates[@]}"; do
      indices+=("$i")
    done
    ;;
  none | n)
    exit 0
    ;;
  *)
    # Parse comma-separated list of numbers and ranges
    IFS=',' read -ra parts <<<"$selection"
    for part in "${parts[@]}"; do
      part="${part// /}" # strip spaces
      if [[ $part =~ ^([0-9]+)-([0-9]+)$ ]]; then
        start="${BASH_REMATCH[1]}"
        end="${BASH_REMATCH[2]}"
        for ((n = start; n <= end; n++)); do
          indices+=($((n - 1)))
        done
      elif [[ $part =~ ^[0-9]+$ ]]; then
        indices+=($((part - 1)))
      else
        echo "Invalid selection: $part" >&2
        valid=false
        break
      fi
    done
    ;;
  esac

  [[ $valid == true ]] && break
done

# Delete selected branches
echo ""
for i in "${indices[@]}"; do
  if [[ $i -ge 0 && $i -lt ${#candidates[@]} ]]; then
    branch="${candidates[$i]}"
    git branch -D "$branch"
  fi
done
